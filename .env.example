PORT=3000
NODE_ENV=development

# JWT
SECRET_KEY=your_super_secret_jwt_key_change_in_production
SESSION_SECRET=your_session_secret_key

# MongoDB (use your Atlas user/password; cluster: videocallapp.flfawhy.mongodb.net)
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@videocallapp.flfawhy.mongodb.net/companion_call?retryWrites=true&w=majority

# Redis
REDIS_URL=redis://localhost:6379

# Agora
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Razorpay (Payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Razorpay Payouts (Host Withdrawals)
RAZORPAY_PAYOUT_KEY=rzp_payout_key
RAZORPAY_PAYOUT_SECRET=rzp_payout_secret
RAZORPAY_PAYOUT_ACCOUNT_NUMBER=your_bank_account_number

# Twilio (OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (FCM Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin
ADMIN_EMAIL=admin@companicall.com
ADMIN_PASSWORD=Change_this_password_immediately
